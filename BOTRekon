function getSummaryTextRingkas(parsed) {
  const lines = [
    `📄 *Ringkasan Data PDF*`,
    `• *NAMA MITRA:* ${parsed.namaMitra || '-'}`,
    `• *NIK:* ${parsed.nik || '-'}`,
    `• *NAMA:* ${parsed.nama || '-'}`,
    `• *BA ID:* ${parsed.baId || '-'}`,
    `• *TANGGAL BA:* ${parsed.tanggalBa || '-'}`,
    `• *WO ID:* ${parsed.woId || '-'}`,
    `• *INET:* ${parsed.inet || '-'}`,
    `• *No SC:* ${parsed.noPermintaan || '-'}`
  ];

if (Object.keys(parsed.materialMap).length > 0) {
  lines.push(`\n📦 *Material:*`);
  for (let [key, value] of Object.entries(parsed.materialMap)) {
    lines.push(`- ${key}: ${value} pcs`);
  }
}

  return lines.join('\n');
}

