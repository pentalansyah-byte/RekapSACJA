// ========== SPREADSHEET ==========
function saveParsedDataRingkas(parsed) {
  const sheet = SpreadsheetApp.openById(PDF_SPREADSHEET_ID).getSheetByName(PDF_SHEET_AMALIA);

  // Header tetap untuk AMALIA
  const baseHeaders = [
    'NAMA MITRA', 'NIK', 'NAMA', 'BA ID', 
    'TANGGAL BA', 'WO ID', 'INET', 'No SC'
  ];

  const materialHeaders = Object.keys(parsed.materialMap);
  const allHeaders = baseHeaders.concat(materialHeaders);

  // Ambil header yang ada
  let currentHeaders = [];
  if (sheet.getLastRow() === 0) {
    sheet.appendRow(allHeaders);
    currentHeaders = allHeaders;
  } else {
    currentHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];

    // Tambah header material baru jika belum ada
    materialHeaders.forEach(header => {
      if (!currentHeaders.includes(header)) {
        currentHeaders.push(header);
        sheet.getRange(1, currentHeaders.length, 1, 1).setValue(header);
      }
    });

    // Pastikan urutan headers konsisten
    allHeaders.length = 0;
    allHeaders.push(...currentHeaders);
  }

  // Mapping field parsed ke header tetap
  const fieldMap = {
    'NAMA MITRA': 'namaMitra',
    'NIK': 'nik',
    'NAMA': 'nama',
    'BA ID': 'baId',
    'TANGGAL BA': 'tanggalBa',
    'WO ID': 'woId',
    'INET': 'inet',
    'No SC': 'noPermintaan'
  };

  // Susun data untuk satu baris
  const rowData = allHeaders.map(header => {
    if (fieldMap[header]) {
      return parsed[fieldMap[header]] || '';
    } else {
      return parsed.materialMap[header] || '';
    }
  });

  sheet.appendRow(rowData);
}

