function getSummaryText(parsed) {
  const lines = [];
  lines.push(`📄 *Ringkasan Data PDF*`);
  lines.push(`• *STO:* ${parsed.STO}`);
  lines.push(`• *No Permintaan:* ${parsed.noPermintaan}`);
  lines.push(`• *No Telepon:* ${parsed.noTelepon}`);
  lines.push(`• *No Inet:* ${parsed.noInet}`);
  lines.push(`• *Tanggal WO:* ${parsed.tanggalWO}`);
  lines.push(`• *Tanggal Transaksi:* ${parsed.tanggalTransaksi}`);
  lines.push(`• *Nama Pelanggan:* ${parsed.namaPelanggan}`);
  lines.push(`• *No Kontak:* ${parsed.noKontak}`);
  lines.push(`• *RK/MSAN/ODC:* ${parsed.rk}`);
  lines.push(`• *DP/ODP:* ${parsed.odp}`);
  lines.push(`• *SN ONT:* ${parsed.snOnt}`);
  lines.push(`• *SN PLC:* ${parsed.snPlc}`);
  lines.push(`• *SN WIFI EXT:* ${parsed.snWifi}`);
  lines.push(`• *STB ID:* ${parsed.stb}`);
  lines.push(`• *Teknisi:* ${parsed.teknisi}`);
  lines.push(`• *Mitra:* ${parsed.mitra}`);
  lines.push(`• *Layanan:* ${parsed.layanan}`);
  lines.push(`• *Speed:* ${parsed.speed}`);
  lines.push(`• *STB Tambahan:* ${parsed.stbTambahan}`);

  const mm = parsed.materialMap || {};
  const keys = Object.keys(mm);

  if (keys.length > 0) {
    lines.push(`\n📦 *Material:*`);

    // copy supaya aman saat delete key
    const displayMap = Object.assign({}, mm);

    // --- RAPINYA: tampilkan AC-OF-SM-1-3SL sekali saja ---
    const dc = Number(displayMap['DROP CORE'] || 0);
    const dcall = Number(displayMap['DC ALL'] || 0);

    // kalau dua-duanya ada dan nilainya sama → tampil sekali, hapus salah satu biar tidak dobel
    if (dc > 0 && dcall > 0 && dc === dcall) {
      lines.push(`- AC-OF-SM-1-3SL: ${dc} pcs`);
      delete displayMap['DROP CORE'];
      delete displayMap['DC ALL'];
    }

    // tampilkan sisanya normal
    for (let [key, value] of Object.entries(displayMap)) {
      if (value === '' || value === null || value === undefined) continue;
      const n = Number(value);
      if (!isNaN(n) && n === 0) continue;
      lines.push(`- ${key}: ${value} pcs`);
    }
  }

  return lines.join('\n');
}

