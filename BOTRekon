function getOrCreateFolderByName_(folderName) {
  const it = DriveApp.getFoldersByName(folderName);
  if (it.hasNext()) return it.next();
  return DriveApp.createFolder(folderName);
}

function getNoWoFromUrl_(url) {
  const m = url.match(/[?&]no_wo=([^&]+)/i);
  return m ? decodeURIComponent(m[1]) : ("AMALIA_" + Date.now());
}

function extractPdfUrlFromHtml_(html, baseUrl) {
  // cari URL .pdf di HTML
  let m = html.match(/https?:\/\/[^\s"'<>]+\.pdf(\?[^\s"'<>]+)?/i);
  if (m) return m[0];

  // cari src="...pdf"
  m = html.match(/src\s*=\s*["']([^"']+\.pdf[^"']*)["']/i);
  if (m) {
    const u = m[1];
    if (u.startsWith("http")) return u;
    // relatif -> jadikan absolut
    const base = baseUrl.replace(/\/[^/]*$/, "/");
    return base + u.replace(/^\//, "");
  }

  return null;
}

function savePdfFromAmaliaLink_(url, chatId) {
  const noWo = getNoWoFromUrl_(url);
  const userFolder = getOrCreateTempFolder(chatId);
  const fileName = noWo + ".pdf";

  // ✅ Skip kalau sudah ada (biar cepat)
  const existed = userFolder.getFilesByName(fileName);
  if (existed.hasNext()) return existed.next();

  // helper fetch dengan timeout
  function fetch_(u) {
    return UrlFetchApp.fetch(u, {
      followRedirects: true,
      muteHttpExceptions: true,
      headers: { "User-Agent": "Mozilla/5.0" },
    });
  }

  // 1) fetch link awal
  let res = fetch_(url);

  const code = res.getResponseCode();
  if (code < 200 || code >= 300) throw new Error("HTTP " + code);

  const headers = res.getHeaders();
  const ct = String(headers["Content-Type"] || headers["content-type"] || "").toLowerCase();

  let pdfBlob;

  // 2) jika direct PDF
  if (ct.includes("application/pdf")) {
    pdfBlob = res.getBlob().setName(fileName);

  } else {
    // 3) jika HTML wrapper → cari URL PDF
    const html = res.getContentText();
    const pdfUrl = extractPdfUrlFromHtml_(html, url);
    if (!pdfUrl) throw new Error("Tidak menemukan URL PDF di halaman");

    // fetch pdf
    res = fetch_(pdfUrl);

    const code2 = res.getResponseCode();
    if (code2 < 200 || code2 >= 300) throw new Error("HTTP PDF " + code2);

    pdfBlob = res.getBlob().setName(fileName);
  }

  // 4) simpan ke folder user
  return userFolder.createFile(pdfBlob).setName(fileName);
}

function extractAllUrls_(text) {
  if (!text) return [];
  const m = text.match(/https?:\/\/\S+/gi);
  return m ? m.map(u => u.trim()) : [];
}

function saveManyAmaliaLinks_(urls, chatId) {
  const folder = getOrCreateTempFolder(chatId);

  // batasi 10
  const picked = urls.slice(0, 10);

  // buat request awal (parallel)
  const reqs = picked.map(u => ({
    url: u,
    method: "get",
    followRedirects: true,
    muteHttpExceptions: true,
    headers: { "User-Agent": "Mozilla/5.0" }
  }));

  const resps = UrlFetchApp.fetchAll(reqs);

  let ok = 0, fail = 0;

  for (let i = 0; i < picked.length; i++) {
    try {
      const url = picked[i];
      const noWo = getNoWoFromUrl_(url);
      const fileName = noWo + ".pdf";

      // skip duplikat
      if (folder.getFilesByName(fileName).hasNext()) {
        ok++;
        continue;
      }

      const res = resps[i];
      const code = res.getResponseCode();
      if (code < 200 || code >= 300) throw new Error("HTTP " + code);

      const headers = res.getHeaders();
      const ct = String(headers["Content-Type"] || headers["content-type"] || "").toLowerCase();

      // kalau bukan PDF (HTML wrapper), fallback ke single function
      if (!ct.includes("application/pdf")) {
        savePdfFromAmaliaLink_(url, chatId);
        ok++;
        continue;
      }

      const blob = res.getBlob().setName(fileName);
      folder.createFile(blob);
      ok++;
    } catch (e) {
      fail++;
      Logger.log("❌ batch fail: " + e.message);
    }
  }

  return { ok, fail };
}
