// ✅ PARSER OCR PDF KE STRUKTUR OBJEK
function cleanLineValue(val) {
  return val
    .split(/\d+\.\s*[A-Z ]+ *:/)[0]  // potong sebelum key berikut
    .replace(/[^\w\-\/\. ]+$/, '')   // buang karakter aneh di akhir
    .trim();
}

function extractNoSC(text) {
  const lines = text.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
  const idx = lines.findIndex(line => /^2\.\s*No Permintaan\s*:/i.test(line));
  if (idx !== -1) {
    const part1 = lines[idx + 1]?.replace(/\s/g, '') || '';
    const part2 = lines[idx + 2]?.replace(/\s/g, '') || '';
    return (part1 + part2).trim();
  }
  return '-';
}

function parseOcrToStructuredDataAMALIA(text) {
  const lines = text.split(/\r?\n/).map(line => line.trim()).filter(Boolean);

  const parsed = {
    namaMitra: '',
    nik: '',
    nama: '',
    baId: '-',
    tanggalBa: '-',
    woId: '-',
    inet: '-',
    noPermintaan: '-',
    materialMap: {}
  };

  // === BA ID ===
  const baLine = lines.find(line => line.toLowerCase().includes('no ba:'));
  if (baLine) {
    const match = baLine.match(/no ba\s*:\s*(\d{6,})/i);
    if (match) parsed.baId = match[1];
  }

  // === Nama Mitra ===
  const mitraLine = lines.find(line => line.toLowerCase().includes('nama mitra'));
  if (mitraLine) {
    const match = mitraLine.match(/:\s*(.+)/);
    if (match) parsed.namaMitra = match[1].trim();
  }

  // === No SC (Gabungkan 3 Baris Setelah "No Permintaan") ===
  const noSCIndex = lines.findIndex(line => /no permintaan\s*:/i.test(line));
  if (noSCIndex !== -1) {
    const part1 = (lines[noSCIndex].split(':')[1] || '').trim().replace(/\s+/g, '');
    const part2 = (lines[noSCIndex + 1] || '').replace(/\s+/g, '');
    const part3 = (lines[noSCIndex + 2] || '').replace(/\s+/g, '');
    parsed.noPermintaan = (part1 + part2 + part3).trim();
  }

  // === No Inet ===
  const inetLine = lines.find(line => /no inet/i.test(line));
  if (inetLine) {
    const match = inetLine.match(/no inet\s*:\s*(\d+)/i);
    if (match) parsed.inet = match[1];
  }

  // === Tanggal BA (ambil yang format yyyy-mm-dd) ===
  const tglLine = lines.find(line => /\b\d{4}-\d{2}-\d{2}\b/.test(line));
  if (tglLine) {
    const match = tglLine.match(/\b(\d{4}-\d{2}-\d{2})\b/);
    if (match) parsed.tanggalBa = match[1];
  }

  // === Nama Teknisi ===
  const teknisiMatch = text.match(/Nama\s*\/\s*Notel\s*Teknisi\s*:\s*(.+?)\s*\/\s*/i);
  if (teknisiMatch) parsed.nama = teknisiMatch[1].trim();

  // === Material Raw Extraction ===
  const materialMapRaw = {};
  const startIdx = lines.findIndex(line => line.toLowerCase().includes("material"));
  const endIdx = lines.findIndex(line => line.toLowerCase().includes("koordinat"));

  if (startIdx !== -1 && endIdx !== -1 && endIdx > startIdx) {
    const materialLines = lines.slice(startIdx + 1, endIdx).map(l => l.trim()).filter(Boolean);

    let nameBuffer = [];

    for (let line of materialLines) {
      if (['tes layanan', 'test voice', 'test internet', 'useetv', 'catatan khusus']
            .some(k => line.toLowerCase().includes(k))) continue;

      // Jika baris hanya jumlah (format: ": 50")
      const qtyMatch = line.match(/^:\s*(\d+)/);
      if (qtyMatch && nameBuffer.length > 0) {
        const fullName = nameBuffer.join(' ')
          .replace(/^\d+\.\s*/, '')
          .replace(/\.+$/, '')
          .trim();

        const qty = parseInt(qtyMatch[1], 10);
        const key = normalizeMaterialKey(fullName);

        // anti double
        if (materialMapRaw[key] === qty) {
          // skip
        } else if (materialMapRaw[key] && materialMapRaw[key] !== qty) {
          materialMapRaw[key] = materialMapRaw[key] + qty;
        } else {
          materialMapRaw[key] = qty;
        }

        nameBuffer = [];
        continue;
      }

      // Format langsung: "1. AC-OF-SM-1-3SL : 50"
      const directMatch = line.match(/^\d+\.\s*([A-Z0-9\-\/\. ]+)\s*[:：]\s*(\d+)/i);
      if (directMatch) {
        const name = directMatch[1].trim().replace(/\.+$/, '');
        const qty = parseInt(directMatch[2], 10);
        const key = normalizeMaterialKey(name);

        // anti double
        if (materialMapRaw[key] === qty) {
          // skip
        } else if (materialMapRaw[key] && materialMapRaw[key] !== qty) {
          materialMapRaw[key] = materialMapRaw[key] + qty;
        } else {
          materialMapRaw[key] = qty;
        }

        nameBuffer = [];
        continue;
      }

      // Baris nama material (multi-line)
      if (/^[A-Z0-9\-\/\. ]+$/i.test(line)) {
        nameBuffer.push(line);
      } else {
        nameBuffer = [];
      }
    }
  } // ✅ PENTING: ini penutup blok if(startIdx...)

  // === Mapping ke Header Sheet ===
  const ocrToHeaderMap = {
    'TIANG GALVANIS': 'TIANG GALVANIS',
    'TIANG REGULER': 'TIANG REGULER',
    'AC-OF-SM-1-3SL': ['DROP CORE', 'DC ALL'],
    'PRECON-1C-100-3SL': 'PRECON',
    'PRECON-1C-150-3SL': 'PRECON',
    'PRECON-1C-80-3SL': 'PRECON',
    'S-CLAMP-SPRINER': 'S-CLAMP',
    'CLAMP-HOOK': 'C-HOOK',
    'OTP-FTTH-1': 'OTP',
    'PREKSO INTRA-15-RS': 'PREKSO-15-RS',
    'PREKSO INTRA-20-RS': 'PREKSO-20-RS',
    'TC-2-160': 'TRAY',
    'KLEM-RING-5-LUBANG': 'KLEM-RING-5-LUBANG',
    'SOC-FUJ': 'SOC-FUJ',
    'SOC-ILS': 'SOC-ILS',
    'SOC-SUM': 'SOC-SUM',
    'RJ45-6': 'RJ45',
    'UTP-C6': 'UTP'
  };

  const materialMap = {};
  for (const [ocrKey, value] of Object.entries(materialMapRaw)) {
    const matchedKey = Object.keys(ocrToHeaderMap).find(k =>
      normalizeMaterialKey(ocrKey).includes(normalizeMaterialKey(k))
    );

    if (!matchedKey) continue;

    const headerTarget = ocrToHeaderMap[matchedKey];
    if (Array.isArray(headerTarget)) {
      headerTarget.forEach(h => materialMap[h] = (materialMap[h] || 0) + value);
    } else {
      materialMap[headerTarget] = (materialMap[headerTarget] || 0) + value;
    }
  }

  parsed.materialMap = materialMap;
  return parsed;
}

