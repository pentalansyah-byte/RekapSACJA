// --Untuk BA UTON--//
function parseOcrToStructuredDataUTON(text) {
  const lines = text.split(/\r?\n/).map(line => line.trim()).filter(line => line !== '');
  const findValue = (key) => {
    const line = lines.find(l => l.toLowerCase().startsWith(key.toLowerCase() + ' :') || l.toLowerCase().startsWith(key.toLowerCase() + ':'));
    if (line) {
      const parts = line.split(':');
      return parts.length > 1 ? parts.slice(1).join(':').trim() : '-';
    }
    return '-';
  };

  const layanan = text.includes('☑ 1P') ? '1P [Internet]' : '-';
  const speedMatch = text.match(/☑\s*(\d+MB|\d+ GB)/i);
  const speed = speedMatch ? speedMatch[1].toUpperCase() : '-';

  const dateBlockMatch = text.match(/Tanggal WO\s*:\s*([^\n\r]+?)\s+Tanggal Transaksi\s*:\s*([^\n\r]+?)\s+Nama Pelanggan\s*:\s*([^\n\r]+)/i);

  const ocrToHeaderMap = {
    'TIANG GALVANIS': 'TIANG GALVANIS',
    'TIANG REGULER': 'TIANG REGULER',
    'AC-OF-SM-1-3SL': ['DROP CORE', 'DC ALL'],
    'PRECON-1C-100-3SL': 'PRECON',
    'PRECON-1C-150-3SL': 'PRECON',
    'PRECON-1C-80-3SL': 'PRECON',
    'S-CLAMP-SPRINER': 'S-CLAMP',
    'CLAMP-HOOK': 'C-HOOK',
    'OTP-FTTH-1': 'OTP',
    'PREKSO INTRA-15-RS': 'PREKSO-15-RS',
    'PREKSO INTRA-20-RS': 'PREKSO-20-RS',
    'TC-2-160': 'TRAY',
    'KLEM-RING-5-LUBANG': 'KLEM-RING-5-LUBANG',
    'SOC-FUJ': 'SOC-FUJ',
    'SOC-ILS': 'SOC-ILS',
    'SOC-SUM': 'SOC-SUM',
    'RJ45-6': 'RJ45',
    'UTP-C6': 'UTP'
  };

  const materialMatches = [...text.matchAll(/([A-Z0-9\-\/\. ]+?)\s*:\s*(\d+)\s*(Pcs|Meter)/gi)];
  const materialMap = {};

  materialMatches.forEach(m => {
    const rawName = normalizeMaterialName(m[1]);
    const qty = parseInt(m[2], 10);

    for (const [ocrName, mappedHeader] of Object.entries(ocrToHeaderMap)) {
      const normOcr = normalizeMaterialName(ocrName);
      if (rawName.includes(normOcr)) {
        if (Array.isArray(mappedHeader)) {
          mappedHeader.forEach(h => {
            materialMap[h] = (materialMap[h] || 0) + qty;
          });
        } else {
          materialMap[mappedHeader] = (materialMap[mappedHeader] || 0) + qty;
        }
      }
    }
  });

  return {
    STO: findValue('STO'),
    noPermintaan: findValue('No Permintaan').replace(/\s+/g, ''),
    noTelepon: findValue('No Telepon'),
    noInet: findValue('No Inet'),
    tanggalWO: dateBlockMatch ? dateBlockMatch[1].trim() : '-',
    tanggalTransaksi: dateBlockMatch ? dateBlockMatch[2].trim() : '-',
    namaPelanggan: dateBlockMatch ? dateBlockMatch[3].trim() : '-',
    noKontak: findValue('No Kontak'),
    rk: findValue('RK/MSAN/ODC'),
    odp: findValue('DP/ODP'),
    snOnt: findValue('SN ONT'),
    snPlc: findValue('SN PLC'),
    snWifi: findValue('SN WIFI EXT'),
    stb: findValue('STB ID'),
    teknisi: (() => {
      const match = text.match(/Nama\s*\/\s*Notel\s*Teknisi\s*:\s*([^\n\r:]+?)(?=\s+STB Tambahan\s*:|$)/i);
      return match ? match[1].trim() : '-';
    })(),
    mitra: findValue('Nama Mitra') || findValue('Mitra'),
    stbTambahan: findValue('STB Tambahan'),
    layanan,
    speed,
    materialMap
  };
}

